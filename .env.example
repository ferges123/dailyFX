APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8438
TZ=Europe/Madrid

DATA_DIR=/data
DATABASE_URL=sqlite:////data/app.db

# Required: generate a long random secret key to secure database-stored API keys
# Generate with: openssl rand -hex 32
APP_SECRET_KEY=

# Optional: set to require Bearer token on all mutating endpoints (access password)
# (e.g. generate with: openssl rand -hex 32)
# APP_ACCESS_TOKEN=change-me-generate-a-long-random-token

# Optional: set to true to require authentication for history reviews and images
# REQUIRE_AUTH_FOR_REVIEW=false

# Optional: Public/External URL of your dailyFX instance (required to display images and action buttons in notifications)
# APP_EXTERNAL_URL=http://192.168.1.100:8439

# Optional: Email to contact administrator
# APP_CONTACT_EMAIL=dailyfx@localhost

# Optional: CORS allowed origins (comma-separated list, defaults to localhost and frontend ports)
CORS_ORIGINS=http://localhost:8439,http://127.0.0.1:8439

# Optional: set to any asset ID from your Immich library to enable effect previews
EXAMPLE_ASSET_ID=

# Optional: set to true to enable structured JSON logging (default: false)
# LOG_JSON=false

# Optional: TTL for local Immich thumbnail caching (default: 7d, supports d/h/m/s/w units)
# IMMICH_THUMBNAIL_CACHE_TTL=7d

# Optional: retention period for cache cleanups (default: 30d, supports d/h/m/s/w units)
# IMMICH_THUMBNAIL_CACHE_RETENTION=30d

